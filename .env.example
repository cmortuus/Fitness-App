# Home Gym Tracker Configuration

# Application
DEBUG=false
ENVIRONMENT=production

# Auth — CHANGE THIS to a random string in production!
# deploy.sh auto-generates this on first install
# JWT_SECRET_KEY=change-me-use-a-random-64-char-string

# Database — defaults to SQLite if not set
# DATABASE_URL=sqlite+aiosqlite:///./homegym.db
# For PostgreSQL (requires pip install -e ".[postgres]"):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/homegym
# DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/homegym

# USDA Food API (optional, DEMO_KEY works with rate limits)
# USDA_API_KEY=your-key-here
