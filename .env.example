# Onyx — development environment configuration
# See .env.production.example for the full production template.

# Application
DEBUG=false
ENVIRONMENT=development

# Auth — REQUIRED. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Must be at least 32 characters.  App refuses to boot without this.
# deploy.sh auto-generates this on first install for production.
JWT_SECRET_KEY=dev-secret-please-replace-with-a-real-random-string-at-least-32-chars

# Database (PostgreSQL) — defaults below work with docker-compose.dev.yml
# DATABASE_URL=postgresql+asyncpg://homegym:homegym_secret@localhost:5432/homegym
# DATABASE_SYNC_URL=postgresql://homegym:homegym_secret@localhost:5432/homegym

# USDA Food API (optional, DEMO_KEY works with rate limits)
# USDA_API_KEY=your-key-here

# Community food verification: number of distinct users required to promote a pending food to community (default 1)
# COMMUNITY_FOOD_THRESHOLD=2
