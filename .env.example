# Home Gym Tracker Configuration

# Application
DEBUG=false
ENVIRONMENT=production

# Auth — CHANGE THIS to a random string in production!
# deploy.sh auto-generates this on first install
# JWT_SECRET_KEY=change-me-use-a-random-64-char-string

# Database (PostgreSQL) — defaults below work with docker-compose.dev.yml
# DATABASE_URL=postgresql+asyncpg://homegym:homegym_secret@localhost:5432/homegym
# DATABASE_SYNC_URL=postgresql://homegym:homegym_secret@localhost:5432/homegym

# USDA Food API (optional, DEMO_KEY works with rate limits)
# USDA_API_KEY=your-key-here

# Community food verification: number of distinct users required to promote a pending food to community (default 1)
# COMMUNITY_FOOD_THRESHOLD=2
