# Onyx — production environment configuration
#
# Copy this file to .env on the production server and fill in real values.
# The app refuses to boot if JWT_SECRET_KEY is missing or set to a placeholder.

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# REQUIRED. Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Must be at least 32 characters; rotating invalidates all existing sessions.
JWT_SECRET_KEY=

# ── Database (PostgreSQL in Docker) ──────────────────────────────────────────
# REQUIRED. Generated by deploy.sh on first run if absent.
POSTGRES_PASSWORD=
# docker-compose.yml injects these from POSTGRES_PASSWORD above; override
# only if pointing at an external database.
# DATABASE_URL=postgresql+asyncpg://homegym:PASSWORD@db:5432/homegym
# DATABASE_SYNC_URL=postgresql://homegym:PASSWORD@db:5432/homegym

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.  Include https:// .
CORS_ALLOWED_ORIGINS=https://lethal.dev,https://www.lethal.dev

# ── Observability (Phase 1.2) ────────────────────────────────────────────────
# Sentry DSN from your project settings (free tier covers us).
SENTRY_DSN=
# PostHog project API key.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ── Email (Phase 1.5) ────────────────────────────────────────────────────────
# Resend API key — https://resend.com
RESEND_API_KEY=
EMAIL_FROM="Onyx <noreply@lethal.dev>"

# ── Stripe (Phase 2) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_YEARLY=

# ── Food APIs (optional) ─────────────────────────────────────────────────────
# USDA_API_KEY=
# CALORIENINJAS_API_KEY=
